import numpy as np
import time

def generate_sensor_data(n, noise_std=0.1, failure_prob=0.0):
    """
    Generates a continuous sine wave signal with Gaussian noise 
    and random sensor 'dead' zones (permanent zeroing).
    """
    t = np.linspace(0, 4 * np.pi, n)
    signal = np.sin(t)
    
