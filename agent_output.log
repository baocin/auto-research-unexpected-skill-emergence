import time

def bubble_sort_noisy(arr, noise_prob=0.0):
    """
    Bubble sort implementation where each comparison has a chance 
    to return the wrong result (simulating bit-flip/noise).
    """
    n = len(arr)
    data = arr.copy()
    for i in range(n):
        for j in range(0, n - i - 1):
